# ----------------------------------------------------------------------------
# Environment variables for ytanalysis (YouTube Analytics app)
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and should never be committed.
# ----------------------------------------------------------------------------

# --- YouTube Data API v3 ----------------------------------------------------
# Get a key from https://console.cloud.google.com/ (enable "YouTube Data API v3").
# NEXT_PUBLIC_ version is used by client-side pages; the server-only version is
# used by API routes / trend libraries. Use the same key value for both.
NEXT_PUBLIC_YOUTUBE_API_KEY=
YOUTUBE_API_KEY=

# --- Groq (LLM for AI summaries) --------------------------------------------
# Create an API key at https://console.groq.com/keys
# NOTE: the codebase references the Groq key under three different names
# (legacy inconsistency). Set all three to the same value to be safe.
NEXT_PUBLIC_GROQ_API_KEY=
GROQ_API_KEY=
groq_api_key=

# Groq model ids (optional — sensible defaults exist in code).
# Must be a CURRENT Groq model — see https://console.groq.com/docs/models
# (older ids like llama3-70b-8192 / mixtral-8x7b-32768 are decommissioned).
NEXT_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile
groq_api_model=llama-3.3-70b-versatile
QWEN_MODEL_ID=llama-3.3-70b-versatile

# --- AI providers: primary + final fallback ---------------------------------
# The app calls AI as: Gemini (primary) -> Groq (fallback) -> Ollama Cloud (final).
# Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Ollama Cloud key from https://ollama.com/settings/keys
# Use a fast NON-reasoning model so it returns answers directly (no wasted
# "thinking" tokens). Alternatives: qwen3-coder:480b, qwen3-vl:235b-instruct.
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:27b

# --- Firebase (Auth + Firestore) --------------------------------------------
# From the Firebase console > Project settings > Your apps > Web app config.
# These are public client-side config values (must be NEXT_PUBLIC_).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Google Sheets (save comparisons) ---------------------------------------
# OAuth 2.0 Web client ID from Google Cloud console (used by gapi, client-side).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# The spreadsheet ID comparisons are appended to.
NEXT_PUBLIC_GOOGLE_SHEET_ID=

# --- Misc -------------------------------------------------------------------
# Rate limit for the trends API route (requests per minute).
MAX_REQUESTS_PER_MINUTE=60
